{
    "name": "@perspective-dev/anywidget",
    "version": "4.5.1",
    "description": "The `PerspectiveWidget` anywidget bundle for `perspective-python` (shipped in the wheel and loaded by anywidget). Not a JupyterLab labextension.",
    "type": "module",
    "private": true,
    "exports": {
        ".": "./src/js/index.js"
    },
    "files": [
        "src/**/*"
    ],
